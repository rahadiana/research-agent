# === Research Agent Configuration ===
#
# Minimal setup — cukup `docker compose up -d`
# Search & LLM auto pake OpenCode SDK, gak perlu API key!

# LLM Provider
# - Kosongin → auto pake OpenCode SDK (default, gratis)
# - Isi kalo mau pake OpenAI langsung
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# Search (opsional — default pake OpenCode SDK)
# SERPAPI_KEY=your-serpapi-key

# Dashboard
DASHBOARD_PORT=3000
DASHBOARD_HOST=0.0.0.0

# Storage
DATA_DIR=./data
